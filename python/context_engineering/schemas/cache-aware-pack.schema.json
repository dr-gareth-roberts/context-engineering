{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "CacheAwarePack",
  "title": "CacheAwarePack",
  "description": "Cache-topology-aware context pack with prefix caching metadata",
  "type": "object",
  "required": ["budget", "selected", "dropped", "totalTokens", "cacheKey", "cacheableTokens", "volatileTokens", "cacheEfficiency", "partitionBoundaries"],
  "properties": {
    "budget": {
      "type": "object",
      "required": ["maxTokens"],
      "properties": {
        "maxTokens": { "type": "number" },
        "reserveTokens": { "type": "number" }
      }
    },
    "selected": {
      "type": "array",
      "items": { "$ref": "ContextItem" }
    },
    "dropped": {
      "type": "array",
      "items": { "$ref": "ContextItem" }
    },
    "totalTokens": { "type": "number" },
    "stats": { "type": "object", "additionalProperties": true },
    "cacheKey": { "type": "string", "description": "Hash of the stable prefix — same hash means cache hit" },
    "cacheableTokens": { "type": "number", "description": "Tokens in the stable prefix (cacheable)" },
    "volatileTokens": { "type": "number", "description": "Tokens in the volatile suffix (changes per request)" },
    "cacheEfficiency": { "type": "number", "minimum": 0, "maximum": 1, "description": "Ratio of cacheable to total tokens" },
    "partitionBoundaries": {
      "type": "array",
      "items": { "type": "number" },
      "description": "Partition boundaries: [staticEnd, sessionEnd]"
    }
  },
  "additionalProperties": true
}
