{
  "name": "@context-engineering/cli",
  "version": "0.1.0",
  "publishConfig": {
    "provenance": true
  },
  "type": "module",
  "description": "CLI for context packing, placement, quality analysis, cost estimation, agent handoff, linting, and budgets",
  "license": "MIT",
  "author": "Dr Gareth Roberts <gareth@zmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/dr-gareth-roberts/context-engineering.git",
    "directory": "packages/ce-cli"
  },
  "homepage": "https://github.com/dr-gareth-roberts/context-engineering/tree/main/packages/ce-cli",
  "bugs": {
    "url": "https://github.com/dr-gareth-roberts/context-engineering/issues"
  },
  "keywords": [
    "context-engineering",
    "cli",
    "llm",
    "token-budget",
    "prefix-cache",
    "agent-handoff",
    "beads",
    "cost-estimation",
    "ai"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "ce": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs');const p=require('path');const src=p.resolve(__dirname,'..','..','schemas');const dst=p.resolve(__dirname,'schemas');if(!fs.existsSync(dst))fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src)){if(f.endsWith('.json'))fs.copyFileSync(p.join(src,f),p.join(dst,f))}\"",
    "build": "tsc -p tsconfig.json",
    "test": "pnpm run build && vitest run",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@context-engineering/core": "workspace:*",
    "@context-engineering/providers": "workspace:*",
    "ajv": "^8.20.0",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
