{
  "name": "@ce/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI for context packing, placement, quality analysis, cost estimation, agent handoff, linting, and budgets",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/context-engineering/toolkit",
    "directory": "packages/ce-cli"
  },
  "keywords": [
    "context-engineering",
    "cli",
    "llm",
    "token-budget",
    "prefix-cache",
    "agent-handoff",
    "beads",
    "cost-estimation",
    "ai"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "ce": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs');const p=require('path');const src=p.resolve(__dirname,'..','..','schemas');const dst=p.resolve(__dirname,'schemas');if(!fs.existsSync(dst))fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src)){if(f.endsWith('.json'))fs.copyFileSync(p.join(src,f),p.join(dst,f))}\"",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ce/core": "workspace:*",
    "@ce/providers": "workspace:*",
    "ajv": "^8.17.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
