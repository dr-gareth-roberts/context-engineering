  },
  "dependencies": {
    "@ce/core": "workspace:*",
    "@ce/providers": "workspace:*",
    "ajv": "^8.17.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
