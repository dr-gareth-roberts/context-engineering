# ── Server (packages/ce-web-server) ─────────────────────────────────
# Port the Express server listens on (default: 3000)
PORT=3000

# Backend FastAPI URL for /api proxy (default: http://127.0.0.1:8000)
# BACKEND_URL=http://127.0.0.1:8000
# BACKEND_PORT=8000

# CORS origin for /api routes. In production, set to your actual domain.
# In development, defaults to http://localhost:3000.
# CORS_ORIGIN=https://your-domain.com

# Rate limiting (per IP, for /api routes)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=120

# ── Client (packages/ce-web-client) ────────────────────────────────
# Umami analytics (optional)
# VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
# VITE_ANALYTICS_WEBSITE_ID=your-website-id
