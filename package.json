      "lodash": ">=4.17.23",
      "lodash-es": ">=4.17.23",
      "mdast-util-to-hast": ">=13.2.1"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
