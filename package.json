    "@tailwindcss/vite": "^4.1.3",
    "@types/express": "5.0.6",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.11",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "tailwindcss>nanoid": "3.3.7",
      "minimatch": ">=10.2.3",
      "rollup": ">=4.59.0",
