{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cache-aware-pack.schema.json",
  "title": "CacheAwarePack",
  "description": "Cache-topology-aware context pack with prefix caching metadata",
  "type": "object",
  "required": [
    "budget",
    "selected",
    "dropped",
    "totalTokens",
    "cacheKey",
    "cacheableTokens",
    "volatileTokens",
    "cacheEfficiency",
    "partitionBoundaries"
  ],
  "properties": {
    "budget": {
      "type": "object",
      "required": ["maxTokens"],
      "properties": {
        "maxTokens": { "type": "integer" },
        "reserveTokens": { "type": "integer" }
      }
    },
    "selected": {
      "type": "array",
      "items": { "$ref": "context-item.schema.json" }
    },
    "dropped": {
      "type": "array",
      "items": { "$ref": "context-item.schema.json" }
    },
    "totalTokens": { "type": "integer" },
    "stats": { "type": "object", "additionalProperties": true },
    "cacheKey": {
      "type": "string",
      "description": "Hash of the stable prefix — same hash means cache hit"
    },
    "cacheableTokens": {
      "type": "integer",
      "description": "Tokens in the stable prefix (cacheable)"
    },
    "volatileTokens": {
      "type": "integer",
      "description": "Tokens in the volatile suffix (changes per request)"
    },
    "cacheEfficiency": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Ratio of cacheable to total tokens"
    },
    "partitionBoundaries": {
      "type": "array",
      "items": { "type": "integer" },
      "description": "Partition boundaries: [staticEnd, sessionEnd]"
    }
  },
  "additionalProperties": true
}
