{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context-trace.schema.json",
  "title": "ContextTrace",
  "type": "object",
  "required": ["pack", "steps"],
  "properties": {
    "pack": { "$ref": "context-pack.schema.json" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "decision"],
        "properties": {
          "id": { "type": "string" },
          "decision": {
            "type": "string",
            "enum": ["include", "exclude", "compress"]
          },
          "tokens": { "type": "integer" },
          "score": { "type": "number" },
          "reason": { "type": "string" },
          "usedCompression": { "type": "boolean" },
          "compressedTokens": { "type": "integer" }
        },
        "additionalProperties": true
      }
    },
    "createdAt": { "type": "string" }
  },
  "additionalProperties": true
}
