{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline-result.schema.json",
  "title": "PipelineResult",
  "description": "Result of a composable context pipeline build",
  "type": "object",
  "required": [
    "selected",
    "dropped",
    "totalTokens",
    "budget",
    "inputCount",
    "stages"
  ],
  "properties": {
    "selected": {
      "type": "array",
      "items": { "$ref": "context-item.schema.json" }
    },
    "dropped": {
      "type": "array",
      "items": { "$ref": "context-item.schema.json" }
    },
    "totalTokens": { "type": "integer" },
    "budget": {
      "type": "object",
      "required": ["maxTokens"],
      "properties": {
        "maxTokens": { "type": "integer" },
        "reserveTokens": { "type": "integer" }
      }
    },
    "quality": {
      "type": "object",
      "properties": {
        "itemCount": { "type": "integer" },
        "totalTokens": { "type": "integer" },
        "density": { "type": "number" },
        "diversity": { "type": "number" },
        "freshness": { "type": "number" },
        "redundancy": { "type": "number" },
        "overall": { "type": "number" }
      }
    },
    "cacheKey": { "type": "string" },
    "cacheEfficiency": { "type": "number" },
    "cacheableTokens": { "type": "integer" },
    "delta": {
      "type": ["object", "null"],
      "properties": {
        "added": {
          "type": "array",
          "items": { "$ref": "context-item.schema.json" }
        },
        "removedIds": { "type": "array", "items": { "type": "string" } },
        "changed": {
          "type": "array",
          "items": { "$ref": "context-item.schema.json" }
        },
        "keptCount": { "type": "integer" },
        "deltaTokens": { "type": "integer" }
      }
    },
    "allocations": { "type": "object", "additionalProperties": true },
    "allocationEfficiency": { "type": "number" },
    "inputCount": { "type": "integer" },
    "stages": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
